def percent_Completed(cursor, ISBN):
    # Chapters read
    chapters_read = cursor.execute("""
        SELECT Chapters_Completed
        FROM Books
        WHERE ISBN = ?
    """, (ISBN,)).fetchone()[0]

    # Total chapters
    chapters_total = cursor.execute("""
        SELECT Chapters
        FROM Books
        WHERE ISBN = ?
    """, (ISBN,)).fetchone()[0]

    if chapters_total == 0:
        return 0  # Avoid divide-by-zero

    percent = (chapters_read / chapters_total) * 100
    return percent

#----------------------
# [EXTRA]
# Function 5: Graph of Book Completion
#----------------------
def plot_percent_completed(cursor):
    # 1. Get all books that are NOT completed
    rows = cursor.execute("""
        SELECT b.Title, b.ISBN, t.Completed
        FROM Books b
        JOIN Tags t ON b.TagID = t.TagID
        WHERE t.Completed = 0;
    """).fetchall()

    if not rows:
        print("No in-progress books found.")
        return

    titles = []
    percentages = []

    # 2. Compute percent completed for each book
    for title, ISBN, _ in rows:
        chapters_read = cursor.execute("""
            SELECT Chapters_Completed
            FROM Books
            WHERE ISBN = ?
        """, (ISBN,)).fetchone()[0]

        chapters_total = cursor.execute("""
            SELECT Chapters
            FROM Books
            WHERE ISBN = ?
        """, (ISBN,)).fetchone()[0]

        if chapters_total == 0:
            percent = 0
        else:
            percent = (chapters_read / chapters_total) * 100

        titles.append(title)
        percentages.append(percent)

    # y positions
    y_positions = list(range(len(titles)))

    # Plot horizontal bars
    plt.figure(figsize=(10, 6))
    plt.barh(y_positions, percentages, color="brown")

    # Axis settings
    plt.xlabel("Percent Completed (%)")
    plt.title("Current Book Progress")
    plt.xlim(0, 110)
    plt.xticks(range(0, 101, 10))

    # Remove titles from the y-axis
    plt.yticks(y_positions, [""] * len(titles))

    # Add titles to the right of each bar
    for i, (pct, title) in enumerate(zip(percentages, titles)):
        plt.text(pct + 2, i, title, va="center", ha="left")

    plt.tight_layout()
    plt.show()