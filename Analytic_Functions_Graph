#---------------------------------------------------------
# 3.11.5 - FUNCTION: Most Read Genres
#---------------------------------------------------------
def most_Read_Genre(cursor):
    return cursor.execute("""
        SELECT c.Genre, COUNT(b.GenreID) AS genre_count
        FROM Books a
        JOIN BookGenre b ON a.ISBN = b.ISBN
        JOIN Genre c ON b.GenreID = c.GenreID
        GROUP BY b.GenreID
        ORDER BY genre_count DESC
        LIMIT 5;
    """).fetchall()


#---------------------------------------------------------
# FUNCTION: Average Chapter Read Speed
#---------------------------------------------------------
def avg_Chapter_Speed(cursor, ISBN):
    # Chapters read
    chapters_read = cursor.execute("""
        SELECT Chapters_Completed
        FROM Books
        WHERE ISBN = ?
    """, (ISBN,)).fetchone()[0]

    # Total chapters
    chapters_total = cursor.execute("""
        SELECT Chapters
        FROM Books
        WHERE ISBN = ?
    """, (ISBN,)).fetchone()[0]

    # Earliest note timestamp
    date_started = cursor.execute("""
        SELECT c.created_On
        FROM Notes c
        JOIN BookNotes b ON c.NoteID = b.NoteID
        JOIN Books a ON a.ISBN = b.ISBN
        WHERE a.ISBN = ?
        ORDER BY c.created_On ASC
        LIMIT 1
    """, (ISBN,)).fetchone()[0]

    date_started = datetime.strptime(date_started, "%Y-%m-%d %H:%M:%S")
    now = datetime.utcnow()

    # Days elapsed
    days_elapsed = (now - date_started).total_seconds() / 86400
    if days_elapsed <= 0:
        return 0

    # Chapters per day
    return chapters_read / days_elapsed


