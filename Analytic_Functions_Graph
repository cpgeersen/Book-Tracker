# FUNCTION: Display Mission Statement
#---------------------------------------------------------
def display_Mission_Statement(cursor, json_path="app/data/user.json"):
    # Try JSON first
    try:
        with open(json_path, "r") as f:
            profile = json.load(f)
            mission = profile.get("mission_statement")
            if mission and mission.strip():
                return mission
    except (FileNotFoundError, json.JSONDecodeError):
        pass

    # Fallback to DB
    row = cursor.execute("""
        SELECT mission_statement
        FROM Users
        WHERE user_id = 1;
    """).fetchone()

    if row and row[0]:
        return row[0]

    return "No mission statement found."

